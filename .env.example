# =============================================================================
#  Rewind — Environment Variables
#  Copy this file: cp .env.example .env
#
#  LOCAL DEV:  Use localhost hostnames (databases exposed via docker-compose.yml)
#  PRODUCTION: Use Docker service names — postgres, redis, api
# =============================================================================

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev:  postgresql://postgres:postgres@localhost:5433/rewind
# Production: postgresql://postgres:postgres@postgres:5432/rewind
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/rewind"

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local dev:  redis://localhost:6379
# Production: redis://redis:6379
REDIS_URL="redis://localhost:6379"

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3002
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET="super-secret-key-change-me-in-production"

# ─── Ingestor ─────────────────────────────────────────────────────────────────
INGESTOR_PORT=3001

# ─── Dashboard ────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"
# Local dev:  http://localhost:3002
# Production: http://api:3002
API_URL="http://localhost:3002"

# ─── Tracker ──────────────────────────────────────────────────────────────────
# The public WebSocket URL your users' browsers will connect to.
NEXT_PUBLIC_INGESTOR_URL="ws://localhost:3001"

# ─── AI / Semantic Search (Optional) ──────────────────────────────────────────
# Set the provider you want to use: 'google' | 'openai' | 'anthropic'
AI_PROVIDER="google"

# Google Gemini (recommended — free tier available)
GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key-here"

# OpenAI (GPT-4o / text-embedding-3-small)
OPENAI_API_KEY="your-openai-api-key-here"

# Optional: Enable Read-Only Demo Mode (Dashboard UI will show a demo login button and disable destructive actions)
NEXT_PUBLIC_DEMO_MODE="false"

# Anthropic (Claude 3 Sonnet)
ANTHROPIC_API_KEY="your-anthropic-api-key-here"
