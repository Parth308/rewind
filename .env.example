# -----------------------------------------------------------------------------
# Rewind Environment Variables Example
# Copy this file to .env and adjust the values as needed.
# -----------------------------------------------------------------------------

# --- Database ---
# The connection string for PostgreSQL.
# For local dev using docker-compose (port 5433 mapped to 5432):
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/rewind"
# For production (using the docker-compose.prod.yml):
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/rewind"

# --- Redis ---
# Connection string for BullMQ and generic caching.
# Local dev:
REDIS_URL="redis://127.0.0.1:6379"
# Production (using the docker-compose.prod.yml):
# REDIS_URL="redis://redis:6379"

# --- API Configuration ---
# Port for the REST API (apps/api)
PORT=3002
# Secret used for signing JWT tokens for dashboard authentication.
# Generate a secure random string in production (e.g., using `openssl rand -hex 32`)
JWT_SECRET="super-secret-key-change-me"

# --- Ingestor Configuration ---
# Port for the WebSocket/HTTP Ingestor (apps/ingestor)
INGESTOR_PORT=3001

# --- Dashboard Frontend Configuration ---
# URL where the Dashboard is accessible, used for CORS and Next.js public routes.
FRONTEND_URL="http://localhost:3000"
# URL where the API is accessible from the Dashboard.
API_URL="http://localhost:3002"

# --- Tracker Configuration ---
# The URL that the tracker script points to when sending events.
# Typically points to the Ingestor's public URL/IP.
NEXT_PUBLIC_INGESTOR_URL="ws://localhost:3001"
