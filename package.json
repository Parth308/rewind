{
  "name": "rewind",
  "private": true,
  "scripts": {
    "build": "dotenv -e .env -- turbo run build",
    "start": "dotenv -e .env -- turbo run start",
    "dev": "dotenv -e .env -- turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:push": "dotenv -e .env -- pnpm -F @rewind/shared run db:push",
    "db:generate": "dotenv -e .env -- pnpm -F @rewind/shared run db:generate",
    "seed:demo": "dotenv -e .env -- tsx scripts/seed-demo.js"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.22.4",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.4.0"
}
